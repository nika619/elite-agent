# ──────────────────────────────────────────────────
#  ELITE AI Agent v2 — Environment Configuration
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Ollama / LLM ──────────────────────────────────
ELITE_OLLAMA_BASE_URL=http://localhost:11434
ELITE_MODEL_NAME=deepseek-r1:7b

# ── Flask Server ──────────────────────────────────
ELITE_HOST=0.0.0.0
ELITE_PORT=5000
ELITE_DEBUG=false
ELITE_SECRET_KEY=change-me-to-a-random-secret

# ── Telegram Notifications (optional) ────────────
ELITE_TELEGRAM_BOT_TOKEN=
ELITE_TELEGRAM_CHAT_ID=

# ── Agent Settings ────────────────────────────────
ELITE_CODER_MAX_RETRIES=10
ELITE_CODER_TIMEOUT=30
ELITE_SEARCH_MAX_RESULTS=5

# ── Logging ───────────────────────────────────────
ELITE_LOG_LEVEL=INFO
ELITE_LOG_FORMAT=text
